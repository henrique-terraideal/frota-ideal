{
  "name": "PlanoManutencao",
  "type": "object",
  "properties": {
    "ativo_id": {
      "type": "string",
      "title": "Ativo"
    },
    "ativo_nome": {
      "type": "string",
      "title": "Nome do Ativo"
    },
    "titulo": {
      "type": "string",
      "title": "T\u00edtulo",
      "description": "Ex: Troca de \u00f3leo do motor"
    },
    "tipo_manutencao": {
      "type": "string",
      "enum": [
        "lavagem",
        "revisao_concessionaria",
        "calibragem",
        "troca_oleo",
        "corretiva",
        "outro"
      ],
      "title": "Tipo de Manuten\u00e7\u00e3o",
      "default": "outro"
    },
    "ativo": {
      "type": "boolean",
      "title": "Ativo",
      "default": true
    },
    "gatilho_uso": {
      "type": "number",
      "title": "A cada (unidade de uso)",
      "description": "Repetir a cada X unidades de uso (km, horas ou ciclos). Deixe vazio se n\u00e3o for por uso."
    },
    "gatilho_tempo_valor": {
      "type": "number",
      "title": "A cada (valor)",
      "description": "Repetir a cada X unidades de tempo. Deixe vazio se n\u00e3o for por tempo."
    },
    "gatilho_tempo_unidade": {
      "type": "string",
      "enum": [
        "dias",
        "semanas",
        "meses",
        "anos"
      ],
      "title": "Unidade de tempo"
    },
    "ultima_execucao_leitura": {
      "type": "number",
      "title": "Leitura de Uso na \u00daltima Execu\u00e7\u00e3o",
      "default": 0
    },
    "ultima_execucao_data": {
      "type": "string",
      "format": "date",
      "title": "Data da \u00faltima execu\u00e7\u00e3o"
    },
    "descricao": {
      "type": "string",
      "title": "Descri\u00e7\u00e3o"
    }
  },
  "required": [
    "ativo_id",
    "titulo"
  ]
}